<% content_for :title, "Solid GCP dummy dashboard" %>

<style>
  body { font-family: system-ui, sans-serif; margin: 1.5rem; max-width: 70rem; }
  h1 { margin-bottom: 0.25rem; }
  .mode { color: #555; font-size: 0.9rem; margin-bottom: 1rem; }
  .flash { padding: 0.5rem 0.75rem; border-radius: 4px; margin-bottom: 1rem; }
  .flash.notice { background: #e6f4ea; }
  .flash.alert { background: #fce8e6; }
  .demos form { display: inline-block; margin: 0 0.4rem 0.4rem 0; }
  button { padding: 0.4rem 0.7rem; cursor: pointer; }
  table { border-collapse: collapse; width: 100%; margin-top: 0.5rem; font-size: 0.85rem; }
  th, td { border: 1px solid #ddd; padding: 0.3rem 0.5rem; text-align: left; vertical-align: top; }
  th { background: #f5f5f5; }
  section { margin-top: 1.75rem; }
  code { font-size: 0.8rem; }
  .empty { color: #888; font-style: italic; }
</style>

<h1>Solid GCP dummy dashboard</h1>
<p class="mode">Adapter mode: <strong><%= @mode %></strong>
  <% if @mode == :local %>(delays elapse in-process; refresh to watch rows appear)<% end %>
</p>

<% flash.each do |type, msg| %>
  <div class="flash <%= type %>"><%= msg %></div>
<% end %>

<section class="demos">
  <h2>Enqueue a demo job</h2>
  <%= button_to "Ping",             enqueue_demo_path("ping") %>
  <%= button_to "Flaky webhook",    enqueue_demo_path("flaky") %>
  <%= button_to "Doomed (fails)",   enqueue_demo_path("doomed") %>
  <%= button_to "Singleton x3",     enqueue_demo_path("singleton") %>
  <%= button_to "Per-user digest x3", enqueue_demo_path("digest") %>
  <%= button_to "Escalation (delays)", enqueue_demo_path("escalation") %>
  <%= button_to "Fake import (cloud_run_job)", enqueue_demo_path("import") %>
</section>

<section>
  <h2>Failed jobs (<%= @failed_jobs.size %>)</h2>
  <% if @failed_jobs.empty? %>
    <p class="empty">None.</p>
  <% else %>
    <table>
      <tr><th>#</th><th>Job</th><th>Error</th><th>Failed at</th><th></th></tr>
      <% @failed_jobs.each do |failed| %>
        <tr>
          <td><%= failed.id %></td>
          <td><%= failed.job_class %></td>
          <td><code><%= failed.error_class %>: <%= failed.error_message %></code></td>
          <td><%= failed.failed_at&.strftime("%H:%M:%S") %></td>
          <td><%= button_to "Retry", retry_failed_job_path(failed.id) %></td>
        </tr>
      <% end %>
    </table>
  <% end %>
</section>

<section>
  <h2>Recent JobRuns (<%= @job_runs.size %>)</h2>
  <% if @job_runs.empty? %>
    <p class="empty">None yet — click a demo button above.</p>
  <% else %>
    <table>
      <tr><th>Ran at</th><th>Job</th><th>Args</th><th>Note</th></tr>
      <% @job_runs.each do |run| %>
        <tr>
          <td><%= run.ran_at.strftime("%H:%M:%S") %></td>
          <td><%= run.job_class %></td>
          <td><code><%= run.args %></code></td>
          <td><%= run.note %></td>
        </tr>
      <% end %>
    </table>
  <% end %>
</section>
